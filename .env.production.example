# 服务器生产环境配置模板
# 复制此文件为 .env.production 并填入真实值
# 注意：此文件包含敏感信息，不要提交到 Git！

# Django 密钥（请生成随机字符串）
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=canway.site,www.canway.site,m.canway.site,api.canway.site

# PostgreSQL
POSTGRES_DB=hr_system
POSTGRES_USER=hr_user
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://hr_user:replace_with_strong_password@postgres:5432/hr_system

# Redis
REDIS_URL=redis://redis:6379/1

# CORS / CSRF
CORS_ALLOW_ALL=False
CORS_ORIGINS=https://canway.site,https://m.canway.site,https://api.canway.site

# 安全
SECURE_SSL_REDIRECT=True

# QQ邮箱配置（用于发送验证码）
EMAIL_HOST_USER=your-qq-email@qq.com
EMAIL_HOST_PASSWORD=your-qq-smtp-authorization-code
DEFAULT_FROM_EMAIL=your-qq-email@qq.com

# 高德地图配置（前端构建需要）
VITE_AMAP_KEY=your-amap-key
VITE_AMAP_SECURITY_JS_CODE=your-amap-security-code
